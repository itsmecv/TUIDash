# TUIDash Configuration
# Copy this file to .env and fill in your values

# Location (Seattle downtown by default)
LATITUDE=47.6062
LONGITUDE=-122.3321

# NOAA Tides station ID (Seattle = 9447130)
# Find stations at: https://tidesandcurrents.noaa.gov/
TIDES_STATION_ID=9447130

# WSDOT Ferries API Key
# Register at: https://wsdot.wa.gov/traffic/api/
WSDOT_API_KEY=your_wsdot_api_key_here

# Ferry route code (ed-king = Edmonds-Kingston)
FERRY_ROUTE=ed-king

# Azure AD App Registration (for Outlook calendar)
# Create app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Required API permissions: Calendars.Read, User.Read
# Enable "Allow public client flows" for device code auth
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_TENANT_ID=your_azure_tenant_id_here

# Refresh interval in seconds (default: 300 = 5 minutes)
REFRESH_INTERVAL=300
